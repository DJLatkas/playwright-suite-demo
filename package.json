{
  "name": "playwright-ts-demo",
  "version": "1.0.0",
  "description": "Production-grade Playwright + TypeScript QA demo with co-located Express app",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node app/server.ts",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api",
    "test:a11y": "playwright test tests/accessibility",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "demo:break": "node scripts/demo-break.js",
    "demo:fix": "node scripts/demo-fix.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "axe-core": "^4.9.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
